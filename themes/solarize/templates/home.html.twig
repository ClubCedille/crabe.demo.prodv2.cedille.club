{% set data_source = data_source|default(page) %}
{% set banner_pic = data_source.media[data_source.header.banner_pic].url %}
{% extends 'partials/base.html.twig' %}
{% set columns = 3 %}
{% set column_units = column_units ?: (12 // columns) %}
{% block pagestyles %}
    {% do assets.addCss('theme://css/home.css') %}
{% endblock %}

{% block banner %}
	{% include 'partials/banner.html.twig' %}
{% endblock banner %}

{% block body %}

    {% set intro = page.header.intro %}
    {% set overview = page.header.overview %}
    <div class="overview-wrapper">
        <section class="container">
            <div id="main-banner">
                <div class="banner-symbol" style='color:rgb(255, 120, 30);'>?</div>
                {{ overview.message|raw }}
                <div class="banner-symbol" style='color:rgb(255, 120, 30);'>?</div>
            </div>
            <div id="links-grid">
                {% for t in overview.links %}
                <div class="link-box">
                    <img src="{{ data_source.media[t.pic].url }}">
                    <div class="link-box-text">
                        <div class="link-description">
                            <div class="link-header">{{ t.title|raw }}</div>
                            <div class="link-element">
                                <a href="{{ t.link }}" target="_blank">{{ t.link_text }}</a>
                            </div>
                        </div>
                        <div class="link-box-desc">{{ t.description|raw }}</div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </section>
    </div>
    <div class="wrapper style2 evenpart">
        <section class="container">
            <h1>{{ intro.title }}</h1>
            <div class="introduction-container">
                {% for t in intro.text %}
                <div class="intro-text">{{ t|raw }}</div>
                {% endfor %}
            </div>
        </section>
    </div>

    {% set missions = page.header.mission %}
    <div class="wrapper style4 plain">
        <section class="container">
            <header class="major">
                <h2>{{ missions.heading|raw }}</h2>
                <span class="byline">{{ missions.byline|raw }}</span>
            </header>
            <div class="row flush">
                <div class="mission-box-container">
                    {% for item in missions.items %}
                    <div class="mission-box">
                        <div class="mission-header">
                            <span class="mission-icon fa-solid fa-{{ item.icon }}"></span>
                            <h3>{{ item.heading|raw }}</h3>
                        </div>
                        <p>{{ item.point|raw }}</p>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </section>
    </div>

    {% set act = data_source.header.activities %}
    <div class="wrapper green-sect">
        <section class="container">
            <div class="green-sect-container">
                <div>
                    <h1>{{ act.title }}</h1>
                    <h2>{{ act.subtitle }}</h2>
                    <div>{{ act.description }}</div>
                </div>
            </div>
            <div class="green-sect-container collage">
                <div class="photo-sect">
                    {% for pic in act.pictures %}
                    <img class="picture-{{ loop.index0 % 4 + 1 }}" src="{{ data_source.media[pic].url }}">
                    {% endfor %}
                </div>
            </div>
        </section>
    </div>

    {% set join = page.header.join %}
    <div class="wrapper style2 evenpart">
        <section class="container">
            <h1>{{ join.title }}</h1>
            <div>{{ join.text|raw }}</div>
            <div class="join-btn-container">
                <a class="page-join-btn" href="{{ join.link }}">{{ join.button|raw }} <i class="fa-solid fa-circle-chevron-right"></i></a>
            </div>
        </section>
    </div>

{% endblock body %}
